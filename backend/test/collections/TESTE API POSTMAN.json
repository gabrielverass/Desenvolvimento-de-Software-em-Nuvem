  "item": [
    {
      "name": "1 - LOGIN COMO USUÁRIO",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Verifica se o status é 200\r",
              "pm.test(\"Login com Usuário padrão\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Verifica se o token jwt foi retornado\r",
              "pm.test(\"Token JWT retornado\", function () {\r",
              "    pm.expect(pm.response.json().resultado.token).to.not.be.null;\r",
              "});\r",
              "\r",
              "//Verifica se o usuário foi retornado\r",
              "pm.test(\"ID do usuário retornado\", function () {\r",
              "    pm.expect(pm.response.json().resultado.user.id).to.not.be.null;\r",
              "    });\r",
              "\r",
              "//armazena o token jwt\r",
              "if(pm.response.json().resultado.token){\r",
              "    pm.environment.set(\"TOKEN_JWT\", pm.response.json().resultado.token);\r",
              "};\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"{{USER_EMAIL}}\",\r\n    \"senha\": \"{{USER_PASSWORD}}\"\r\n}",
          "options": {
            "raw": {
